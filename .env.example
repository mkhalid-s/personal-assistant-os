# Personal Assistant OS example configuration
# Copy to data/.env.myos or another local, ignored env file before filling secrets.

# Optional custom DB path. Defaults to ./data/assistant.db when unset.
MYOS_DB_PATH=./data/assistant.db

# Optional external connectors. Leave blank to run local-only.
JIRA_BASE_URL=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=

GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

CONFLUENCE_BASE_URL=
CONFLUENCE_USER_EMAIL=
CONFLUENCE_API_TOKEN=

AHA_BASE_URL=
AHA_API_TOKEN=

# Optional connector hardening.
MYOS_CONNECTOR_RETRIES=3
MYOS_CONNECTOR_BACKOFF_SEC=1.2
MYOS_CONNECTOR_TIMEOUT_SEC=25

# Optional reasoning provider command. Leave blank for deterministic local fallback paths.
MYOS_AI_COMMAND=

# Safe default: approved external actions are written to data/outbox, not sent.
MYOS_ACTION_PROVIDER=builtin
MYOS_ACTION_COMMAND=myos action-provider

# Optional notification hook for assistant digests.
MYOS_NOTIFY_COMMAND=
